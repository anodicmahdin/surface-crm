# Database (Supabase)
# Use the TRANSACTION POOLER url (port 6543) for DATABASE_URL on Vercel/serverless
# Found in: Supabase → Settings → Database → Connection string → Transaction pooler
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres"

# Use the DIRECT connection url (port 5432) for DIRECT_URL (used for migrations only)
# Found in: Supabase → Settings → Database → Connection string → Direct connection
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Auth (Clerk) — https://clerk.com/dashboard
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""

# Email (Resend) — https://resend.com/api-keys
RESEND_API_KEY=""

# Background Jobs (Inngest) — https://inngest.com
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# Enrichment (optional)
APOLLO_API_KEY=""
CLAY_API_KEY=""

# Slack (optional)
SLACK_WEBHOOK_URL=""

# Gmail OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Monitoring (optional)
SENTRY_DSN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST=""

# Webhooks
WEBHOOK_SIGNING_SECRET=""

# App URL — set to your Vercel deployment URL in production
NEXT_PUBLIC_APP_URL="http://localhost:3000"
