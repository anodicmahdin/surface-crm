# Copy to Vercel → Project → Settings → Environment Variables (Production + Preview)

# --- Database (required) ---
# DATABASE_URL: Supabase "Transaction" pooler (port 6543) — required for serverless connection limits
# DIRECT_URL: "Session" or direct Postgres (port 5432) — used by Prisma Migrate; optional at runtime if you migrate from CI
DATABASE_URL=""
DIRECT_URL=""

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Clerk (https://dashboard.clerk.com) ---
# Add your Vercel URL under: Clerk → Configure → Domains (e.g. https://your-app.vercel.app)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""

# --- App URL (required for production) ---
# Set to your production URL, e.g. https://your-app.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Inngest (https://app.inngest.com) ---
# Point the Inngest app URL to: https://YOUR_DOMAIN/api/inngest
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# --- Email ---
RESEND_API_KEY=""

# --- Optional integrations ---
APOLLO_API_KEY=""
CLAY_API_KEY=""
SLACK_WEBHOOK_URL=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
SENTRY_DSN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST=""
WEBHOOK_SIGNING_SECRET=""
